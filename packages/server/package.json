{
  "name": "@stark-o/server",
  "version": "0.0.1",
  "description": "Orchestrator server with REST API and WebSocket for Stark",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "chaos": "tsx src/chaos-cli.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@stark-o/core": "workspace:*",
    "@stark-o/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "express-slow-down": "^3.1.0",
    "http-proxy": "^1.18.1",
    "selfsigned": "^2.4.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^20.19.39",
    "@types/selfsigned": "^2.1.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
